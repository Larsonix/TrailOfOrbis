# =============================================================================
# Vanilla Item Conversion Configuration
# =============================================================================
# Converts vanilla Hytale weapons and armor into RPG gear when acquired
# through mob drops, chest loot, or crafting.
#
# OVERVIEW:
# ---------
# When enabled, vanilla weapons and armor are automatically converted to RPG
# gear with random stats, modifiers, and quality. The item's material determines
# the maximum rarity it can roll (e.g., wood can only be Common, steel can be Epic).
#
# ACQUISITION SOURCES:
# - Mob drops: Uses the mob's level
# - Chest loot: Uses distance from spawn to determine level
# - Crafting: Uses the player's current RPG level
#
# Items picked up from the ground (dropped by players) are NOT converted.
# =============================================================================

# Master switch for the entire conversion system
enabled: true

# -----------------------------------------------------------------------------
# CONVERSION SOURCES
# -----------------------------------------------------------------------------
# Enable/disable conversion for specific acquisition methods.
# Ground pickups are intentionally excluded to prevent exploit loops.

sources:
  # Convert weapons/armor dropped by mobs
  mob_drops: true

  # Convert weapons/armor found in treasure chests
  chest_loot: true

  # Convert weapons/armor created through crafting
  crafting: true

# -----------------------------------------------------------------------------
# ITEM FILTERING
# -----------------------------------------------------------------------------
# Control which items can be converted using whitelist/blacklist.
#
# WHITELIST: When non-empty, ONLY these item IDs are converted
# BLACKLIST: These item IDs are NEVER converted (takes priority over whitelist)
#
# Item IDs follow Hytale naming: e.g., "Weapon_Sword_Iron", "Armor_Steel_Chest"

# Only convert these items (empty = all weapons/armor)
whitelist: []

# Never convert these items (overrides whitelist)
blacklist: []

# -----------------------------------------------------------------------------
# MATERIAL TIER MAPPINGS
# -----------------------------------------------------------------------------
# Maps material names to maximum rarity tiers.
#
# When an item is converted, its rarity is rolled randomly but CAPPED at the
# maximum allowed by its material. A wooden sword cannot be Epic, but an iron
# sword could roll anywhere from Common to Rare.
#
# RARITY TIERS (lowest to highest):
# COMMON, UNCOMMON, RARE, EPIC, LEGENDARY, MYTHIC
#
# Material is extracted from item ID:
# - "Weapon_Sword_Iron" -> "iron"
# - "Armor_Steel_Chest" -> "steel"

material_tiers:
  # Natural/primitive materials
  wood: COMMON
  bone: COMMON
  stone: COMMON

  # Early metals
  copper: UNCOMMON
  bronze: RARE

  # Standard metals
  iron: RARE
  steel: EPIC

  # Advanced/magical materials — capped at EPIC for crafting.
  # Legendary and Mythic are realm-exclusive rewards.
  cobalt: EPIC
  mithril: EPIC
  adamantite: EPIC
  obsidian: EPIC

  # Special materials (if they exist)
  gold: RARE         # Fragile but magical
  silver: RARE       # Good vs undead
  leather: UNCOMMON  # Light armor
  hide: COMMON       # Basic armor
  cloth: COMMON      # Robes

# Default max rarity for materials not listed above
default_max_rarity: RARE

# -----------------------------------------------------------------------------
# MATERIAL DISTANCES (Crafting Level System)
# -----------------------------------------------------------------------------
# Where materials are found in the overworld (distance from spawn in blocks).
# Crafted gear level is computed using the SAME formula as mob scaling:
#   level = 1 + (distance - scalingStart) / blocksPerLevel
#
# Change mob scaling parameters in mob-scaling.yml -> crafting levels
# automatically stay in sync. Only change these if you want to adjust
# WHERE materials are considered to spawn.

material_distances:
  # Primitive (near spawn)
  wood:       { min: 0,    max: 400  }
  bone:       { min: 0,    max: 400  }
  crude:      { min: 0,    max: 300  }
  hide:       { min: 0,    max: 400  }
  cloth:      { min: 0,    max: 500  }
  stone:      { min: 0,    max: 400  }

  # Early metals
  copper:     { min: 200,  max: 700  }
  leather:    { min: 200,  max: 700  }

  # Mid metals
  bronze:     { min: 500,  max: 1200 }
  iron:       { min: 700,  max: 1500 }
  gold:       { min: 700,  max: 1500 }
  silver:     { min: 700,  max: 1500 }
  steel:      { min: 1000, max: 2000 }

  # Advanced metals
  thorium:    { min: 1500, max: 2500 }
  cobalt:     { min: 2000, max: 3000 }

  # Endgame metals
  mithril:    { min: 2500, max: 4000 }
  adamantite: { min: 3500, max: 5000 }
  obsidian:   { min: 3500, max: 5000 }

# Fallback for unknown materials (from other mods)
default_distance: { min: 500, max: 1500 }

# Global multiplier for crafted gear level.
# 1.0 = gear matches zone mobs exactly.
# 0.9 = crafted gear is ~10% weaker (rewards drops over crafting).
# Only change if you want to shift the core feeling of crafting vs drops.
crafting_level_multiplier: 1.0

# -----------------------------------------------------------------------------
# LEVEL CALCULATION (Legacy)
# -----------------------------------------------------------------------------
# Used for mob drops and chest loot level clamping.

level_calculation:
  min_level: 1
  max_level: 1000000
  crafting_level_offset: 0

# -----------------------------------------------------------------------------
# RARITY BONUSES
# -----------------------------------------------------------------------------
# Additional rarity bonus applied during conversion (stacks with other bonuses).
# Higher values shift the probability toward rarer results.

rarity_bonus:
  # Bonus for mob drops (higher = rarer drops from mobs)
  mob_drops: 0.0

  # Bonus for chest loot (treasure chests tend to have better items)
  chest_loot: 0.5

  # Bonus for crafting (skilled crafters can make better items)
  crafting: 0.0
