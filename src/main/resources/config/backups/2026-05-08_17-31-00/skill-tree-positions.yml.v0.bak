# ══════════════════════════════════════════════════════════════════════════════
# SKILL TREE NODE POSITIONS
# ══════════════════════════════════════════════════════════════════════════════
#
# Coordinates are in world blocks relative to sanctum center (0, 65, 0).
#
# Directions:
#   - X+ = East (Fire)    X- = West (Water)
#   - Z+ = South (Lightning)    Z- = North (Earth)
#   - Y+ = Up (Void)    Y- = Down (Wind)
#
# ══════════════════════════════════════════════════════════════════════════════

nodes:

  # ─────────────────────────────────────────────────────────────────────────────
  # CORE (origin only)
  # ─────────────────────────────────────────────────────────────────────────────

  origin:
    x: 0.0
    y: 64.0
    z: 0.0

  # ─────────────────────────────────────────────────────────────────────────────
  # HORIZONTAL CORNER BRIDGES (4 bridges, 3 nodes each)
  # Connect adjacent outer cluster notables around the horizontal ring
  # Arcs curve inward toward center (chord interpolation between endpoints)
  # ─────────────────────────────────────────────────────────────────────────────

  # FIRE_BERSERKER ↔ LIGHTNING_OVERCHARGE (corner at +X/+Z)
  bridge_fire_lightning_1:
    x: 25.0
    y: 65.0
    z: 12.0

  bridge_fire_lightning_2:
    x: 18.0
    y: 65.0
    z: 18.0

  bridge_fire_lightning_3:
    x: 12.0
    y: 65.0
    z: 25.0

  # LIGHTNING_CHAIN ↔ WATER_SHATTER (corner at -X/+Z)
  bridge_lightning_water_1:
    x: -12.0
    y: 65.0
    z: 24.0

  bridge_lightning_water_2:
    x: -18.0
    y: 65.0
    z: 18.0

  bridge_lightning_water_3:
    x: -25.0
    y: 65.0
    z: 12.0

  # WATER_EVASION ↔ EARTH_FORTITUDE (corner at -X/-Z)
